{#-
Suggested report structure:

- The script derives final report text from structured DB content.
- LLM does not write `report_md` directly.
- The same rendered string is used for both `citation_analysis.json.report_md` and `citation_analysis.md`.
-#}
{% set is_en = language.lower().startswith('en') %}
## {{ "Citation Signals In Review Scope" if is_en else "文献综述章节引文线索" }}

### {{ "Summary" if is_en else "总体总结" }}
{{ summary }}

{% if key_references %}
### {{ "Key References" if is_en else "关键文献" }}
{% for item in key_references %}
- {{ item.citation_label }} {{ item.author_year_label }}{% if item.title %}: {{ item.title }}{% endif %}{% if item.function_label %} ({{ item.function_label }}){% endif %}
{% endfor %}
{% endif %}

### {{ "Scope" if is_en else "范围" }}
- {{ "Section" if is_en else "章节" }}: {{ scope.section_title }}
- {{ "Lines" if is_en else "行号" }}: {{ scope.line_start }}-{{ scope.line_end }}

### {{ "By Function" if is_en else "按功能归类" }}
{% if grouped_items %}
{% for group in grouped_items %}
#### {{ group.function_label }}
{% for item in group["items"] %}
- {{ item.citation_label }} {{ item.author_year_label }}
  - {{ "Title" if is_en else "标题" }}: {{ item.title or ("[missing]" if is_en else "[缺失]") }}
  - {{ "Keywords" if is_en else "关键词" }}: {{ item.keywords | join(", ") if item.keywords else ("[none]" if is_en else "[无]") }}
  - {{ "Summary" if is_en else "总结" }}: {{ item.summary }}
{% endfor %}

{% endfor %}
{% else %}
- {{ "No stable mapped citations in this scope." if is_en else "本范围内未检测到稳定映射的引用。" }}
{% endif %}

### {{ "Timeline Analysis" if is_en else "时间线分析" }}
{% for bucket_name, bucket_label in [("early", "Early" if is_en else "早期"), ("mid", "Mid" if is_en else "中期"), ("recent", "Recent" if is_en else "近期")] %}
#### {{ bucket_label }}
{{ timeline[bucket_name]["summary"] }}
{% if timeline[bucket_name]["items"] %}
{% for item in timeline[bucket_name]["items"] %}
- {{ item.citation_label }} {{ item.author_year_label }}{% if item.title %}: {{ item.title }}{% endif %}
{% endfor %}
{% else %}
- {{ "No representative references in this bucket." if is_en else "该时段没有可列举的代表文献。" }}
{% endif %}

{% endfor %}

{% if unmapped_mentions %}
### {{ "Unmapped Mentions" if is_en else "未映射引用" }}
{% for mention in unmapped_mentions %}
- {{ mention.marker }}{% if mention.reason %} ({{ mention.reason }}){% endif %}{% if mention.snippet %}: {{ mention.snippet }}{% endif %}
{% endfor %}
{% endif %}
